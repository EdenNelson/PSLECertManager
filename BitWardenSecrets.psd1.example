# Copy this file to BitWardenSecrets.psd1 and update with your values
@{
    BitWardenSecrets = @{
        BWSToken = "your-bitwarden-api-token-here"
    }

    ScriptSecrets = @{
        Email        = "your-email-secret-id"
        R53AccessKey = "your-aws-access-key-secret-id"
        R53SecretKey = "your-aws-secret-key-secret-id"
    }
}
